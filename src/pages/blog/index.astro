---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import Annotate from "../../components/Annotate.astro";
import { absoluteUrl, buildPersonRef, siteConfig } from "../../lib/seo";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const [featured, ...rest] = posts;

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: `${siteConfig.shortName} - Blog`,
  description:
    "Notes on product engineering, AI interfaces, developer tools, and the journey of building products.",
  url: absoluteUrl("/blog", Astro.site),
  author: buildPersonRef(Astro.site),
};
---

<Layout
  title="Blog"
  description="Notes on product engineering, AI interfaces, developer tools, and the journey of building products."
  jsonLd={jsonLd}
>
  <main class="isolate">
    <section class="section-shell">
      <div class="section-inner grid gap-12">
        <div class="grid gap-4">
          <p class="text-muted-foreground text-sm">Blog</p>
          <h1
            class="max-w-[24ch] font-serif text-3xl font-normal tracking-tight text-balance italic md:text-5xl"
          >
            Notes on the <Annotate type="underline"
              >journey of building</Annotate
            > products.
          </h1>
        </div>

        {
          featured && (
            <article class="group grid gap-4">
              {featured.data.coverImage && (
                <a
                  href={`/blog/${featured.id}`}
                  aria-label={featured.data.title}
                  class="border-border/60 bg-muted block w-full overflow-hidden rounded-3xl border no-underline ring-1 ring-white/5 ring-inset"
                >
                  <Image
                    src={featured.data.coverImage}
                    alt={featured.data.title}
                    class="block w-full transition-transform duration-700 ease-out group-hover:scale-[1.02]"
                  />
                </a>
              )}
              <p class="text-muted-foreground font-mono text-sm tracking-wide uppercase">
                Latest · {featured.data.category} ·{" "}
                {formatDate(featured.data.date)}
              </p>
              <h2 class="max-w-[28ch] text-3xl font-semibold tracking-tight text-pretty md:text-4xl">
                <a href={`/blog/${featured.id}`}>{featured.data.title}</a>
              </h2>
              <p class="text-muted-foreground max-w-[60ch] text-base text-pretty">
                {featured.data.description}
              </p>
            </article>
          )
        }

        {
          rest.length > 0 && (
            <div class="divide-border/40 border-border/40 grid gap-0 divide-y border-t">
              {rest.map((post, index) => (
                <article class="group grid grid-cols-[88px_1fr] items-start gap-4 py-5 sm:grid-cols-[120px_1fr] sm:gap-6">
                  {post.data.coverImage ? (
                    <a
                      href={`/blog/${post.id}`}
                      aria-label={post.data.title}
                      class="border-border/60 bg-muted block aspect-square overflow-hidden rounded-xl border no-underline ring-1 ring-white/5 ring-inset"
                    >
                      <Image
                        src={post.data.coverImage}
                        alt={post.data.title}
                        loading="lazy"
                        class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.05]"
                      />
                    </a>
                  ) : (
                    <div class="bg-muted aspect-square rounded-xl" />
                  )}
                  <div class="grid gap-1.5">
                    <p class="text-muted-foreground font-mono text-xs tracking-wide uppercase">
                      {post.data.category} · {formatDate(post.data.date)}
                    </p>
                    <h3 class="text-base font-semibold tracking-tight sm:text-lg">
                      <a href={`/blog/${post.id}`}>{post.data.title}</a>
                    </h3>
                    <p class="text-muted-foreground line-clamp-2 max-w-[56ch] text-sm text-pretty">
                      {post.data.description}
                    </p>
                  </div>
                </article>
              ))}
            </div>
          )
        }
      </div>
    </section>
  </main>
</Layout>

<script is:inline>
  document.querySelectorAll('a[href^="/blog/"]').forEach((link) => {
    link.addEventListener("click", () => {
      const slug = link.getAttribute("href").replace("/blog/", "");
      const title = link
        .closest("article")
        ?.querySelector("h2, h3")
        ?.textContent?.trim();
      window.posthog?.capture("blog_post_clicked", {
        post_slug: slug,
        post_title: title ?? null,
      });
    });
  });
</script>
