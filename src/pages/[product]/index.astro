---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import Layout from "../../layouts/Layout.astro";
import Annotate from "../../components/Annotate.astro";
import { absoluteUrl, siteConfig } from "../../lib/seo";

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((product) => ({
    params: { product: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);

const data = product.data;
const supportPath = `/${product.id}/support`;
const marketingPath = `/${product.id}`;
const marketingUrl = absoluteUrl(marketingPath, Astro.site);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: data.name,
    description: data.description,
    url: marketingUrl,
    applicationCategory: data.category,
    operatingSystem: data.platforms.join(", "),
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
    },
    ...(data.appStoreUrl ? { downloadUrl: data.appStoreUrl } : {}),
    featureList: data.features.map((f) => f.title),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: siteConfig.shortName,
        item: absoluteUrl("/", Astro.site),
      },
      {
        "@type": "ListItem",
        position: 2,
        name: data.name,
        item: marketingUrl,
      },
    ],
  },
];
---

<Layout
  title={data.name}
  description={data.tagline}
  canonical={marketingUrl}
  keywords={data.keywords}
  jsonLd={jsonLd}
>
  <main class="isolate">
    <section class="section-shell">
      <div class="section-inner grid gap-12">
        <header class="grid gap-4">
          <div class="text-muted-foreground flex items-center gap-2 text-sm">
            <a href="/" class="no-underline">{siteConfig.shortName}</a>
            <span aria-hidden="true">/</span>
            <span class="text-foreground font-medium">{data.name}</span>
          </div>
          <h1
            class="max-w-[20ch] font-serif text-4xl font-normal tracking-tight text-balance italic md:text-6xl"
          >
            {data.name}
          </h1>
          <p
            class="text-foreground max-w-[44ch] text-xl font-medium tracking-tight text-pretty md:text-2xl"
          >
            <Annotate type="underline">{data.tagline}</Annotate>
          </p>
          <p
            class="text-muted-foreground max-w-[60ch] text-base text-pretty md:text-lg"
          >
            {data.description}
          </p>
          <div class="mt-2 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
            {
              data.appStoreUrl && (
                <a
                  href={data.appStoreUrl}
                  data-no-dialog
                  class="bg-foreground text-background inline-flex items-center gap-2 rounded-full px-5 py-2.5 font-semibold no-underline transition-opacity hover:opacity-90"
                  data-cta="app-store"
                >
                  <Icon name="ri:apple-fill" class="size-4" />
                  Download on the App Store
                </a>
              )
            }
            <a
              href={supportPath}
              class="font-medium no-underline"
              data-cta="support"
            >
              Support
            </a>
            <span class="text-muted-foreground">
              {data.pricing} · {data.platforms.join(" · ")}
            </span>
          </div>
        </header>

        {
          data.screenshots.length > 0 && (
            <div class="border-border/60 bg-muted grid gap-4 overflow-x-auto rounded-3xl border p-4 ring-1 ring-white/5 ring-inset">
              <div class="flex gap-4">
                {data.screenshots.map((shot) => (
                  <Image
                    src={shot}
                    alt={`${data.name} screenshot`}
                    class="h-[420px] w-auto shrink-0 rounded-2xl"
                  />
                ))}
              </div>
            </div>
          )
        }

        {
          data.features.length > 0 && (
            <section class="grid gap-8">
              <h2 class="max-w-[24ch] text-2xl font-semibold tracking-tight md:text-3xl">
                What it does
              </h2>
              <ul role="list" class="grid gap-6 sm:grid-cols-2">
                {data.features.map((feature) => (
                  <li class="border-border/60 grid gap-2 border-t pt-5">
                    <h3 class="text-base font-semibold tracking-tight">
                      {feature.title}
                    </h3>
                    <p class="text-muted-foreground text-sm text-pretty">
                      {feature.description}
                    </p>
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        {
          data.privacyPoints.length > 0 && (
            <section class="grid gap-4">
              <h2 class="max-w-[24ch] text-2xl font-semibold tracking-tight md:text-3xl">
                Private by design
              </h2>
              <ul role="list" class="grid max-w-[60ch] gap-2.5">
                {data.privacyPoints.map((point) => (
                  <li class="text-muted-foreground before:text-muted-foreground/40 relative pl-5 text-base text-pretty before:absolute before:left-0 before:content-['•']">
                    {point}
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        <div class="prose max-w-none overflow-x-hidden">
          <Content />
        </div>

        <footer class="border-border/60 grid gap-4 border-t pt-8 text-sm">
          <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
            <a href={supportPath} class="font-medium" data-cta="support-footer">
              Support and documentation
            </a>
            <a href="/" class="text-muted-foreground no-underline">
              Back to {siteConfig.shortName}
            </a>
          </div>
          <p class="text-muted-foreground text-pretty">
            Built by {siteConfig.name}. {data.pricing}. No ads, no tracking, no
            account.
          </p>
        </footer>
      </div>
    </section>
  </main>
</Layout>

<script is:inline>
  document.querySelectorAll("[data-cta]").forEach((link) => {
    link.addEventListener("click", () => {
      window.posthog?.capture("product_cta_clicked", {
        product: document.title,
        cta: link.dataset.cta,
      });
    });
  });
</script>
