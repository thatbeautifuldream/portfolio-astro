---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import Layout from "../../layouts/Layout.astro";
import Annotate from "../../components/Annotate.astro";
import { absoluteUrl, siteConfig } from "../../lib/seo";

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((product) => ({
    params: { product: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const data = product.data;
const supportPath = `/${product.id}/support`;
const marketingPath = `/${product.id}`;
const supportUrl = absoluteUrl(supportPath, Astro.site);

const jsonLd =
  data.faq.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        url: supportUrl,
        mainEntity: data.faq.map((item) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: item.answer,
          },
        })),
      }
    : undefined;
---

<Layout
  title={`Support · ${data.name}`}
  description={`Support, troubleshooting, and frequently asked questions for ${data.name}.`}
  canonical={supportUrl}
  keywords={[...data.keywords, "support", "help", "faq"]}
  image={`/og/product/${product.id}.png`}
  jsonLd={jsonLd}
>
  <main class="isolate">
    <section class="section-shell">
      <div class="section-inner grid gap-12">
        <header class="grid gap-4">
          <div class="text-muted-foreground flex items-center gap-2 text-sm">
            <a href="/" class="no-underline">{siteConfig.shortName}</a>
            <span aria-hidden="true">/</span>
            <a href={marketingPath} class="no-underline">{data.name}</a>
            <span aria-hidden="true">/</span>
            <span class="text-foreground font-medium">Support</span>
          </div>
          <p class="text-muted-foreground text-sm">Support</p>
          <h1
            class="max-w-[24ch] font-serif text-3xl font-normal tracking-tight text-balance italic md:text-5xl"
          >
            Help and answers for <Annotate type="underline"
              >{data.name}</Annotate
            >.
          </h1>
          <p
            class="text-muted-foreground max-w-[60ch] text-base text-pretty md:text-lg"
          >
            {data.description}
          </p>
        </header>

        {
          data.faq.length > 0 && (
            <section class="grid gap-6">
              <h2 class="text-xl font-semibold tracking-tight md:text-2xl">
                Frequently asked questions
              </h2>
              <div class="divide-border/40 border-border/40 grid divide-y border-t">
                {data.faq.map((item) => (
                  <details class="group grid gap-2 py-5">
                    <summary class="flex cursor-pointer list-none items-start justify-between gap-4 text-base font-medium tracking-tight no-underline marker:hidden">
                      <span>{item.question}</span>
                      <Icon
                        name="ri:add-line"
                        class="text-muted-foreground mt-0.5 size-4 shrink-0 transition-transform group-open:rotate-45"
                      />
                    </summary>
                    <p class="text-muted-foreground max-w-[60ch] text-sm text-pretty">
                      {item.answer}
                    </p>
                  </details>
                ))}
              </div>
            </section>
          )
        }

        <div class="grid gap-10 sm:grid-cols-2">
          {
            data.permissions.length > 0 && (
              <section class="grid gap-3">
                <h2 class="text-lg font-semibold tracking-tight">
                  Permissions
                </h2>
                <ul role="list" class="grid gap-2">
                  {data.permissions.map((perm) => (
                    <li class="text-muted-foreground before:text-muted-foreground/40 relative pl-5 text-sm text-pretty before:absolute before:left-0 before:content-['•']">
                      {perm}
                    </li>
                  ))}
                </ul>
              </section>
            )
          }

          {
            data.requirements.length > 0 && (
              <section class="grid gap-3">
                <h2 class="text-lg font-semibold tracking-tight">
                  Requirements
                </h2>
                <ul role="list" class="grid gap-2">
                  {data.requirements.map((req) => (
                    <li class="text-muted-foreground before:text-muted-foreground/40 relative pl-5 text-sm text-pretty before:absolute before:left-0 before:content-['•']">
                      {req}
                    </li>
                  ))}
                </ul>
              </section>
            )
          }
        </div>

        {
          data.privacyPoints.length > 0 && (
            <section class="grid gap-3">
              <h2 class="text-lg font-semibold tracking-tight">Privacy</h2>
              <ul role="list" class="grid max-w-[60ch] gap-2">
                {data.privacyPoints.map((point) => (
                  <li class="text-muted-foreground before:text-muted-foreground/40 relative pl-5 text-sm text-pretty before:absolute before:left-0 before:content-['•']">
                    {point}
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        <section class="border-border/60 grid gap-4 border-t pt-8">
          <h2 class="text-lg font-semibold tracking-tight">Get in touch</h2>
          <p class="text-muted-foreground max-w-[60ch] text-base text-pretty">
            Still stuck? Email and you'll get a real reply from a real person,
            usually within a day.
          </p>
          <div class="grid gap-2 text-sm">
            {
              data.supportEmail && (
                <a
                  href={`mailto:${data.supportEmail}?subject=${encodeURIComponent(`${data.name} support`)}`}
                  class="font-medium"
                  data-contact="email"
                >
                  {data.supportEmail}
                </a>
              )
            }
            {
              data.supportLinks.map((link) => (
                <a
                  href={link.href}
                  data-no-dialog
                  class="text-muted-foreground font-medium no-underline"
                >
                  {link.label}
                </a>
              ))
            }
            <a
              href={marketingPath}
              class="text-muted-foreground font-medium no-underline"
            >
              Back to {data.name}
            </a>
          </div>
        </section>

        <footer class="text-muted-foreground text-sm text-pretty">
          Built by{" "}
          <a href="/" class="font-medium no-underline">{siteConfig.name}</a>.
        </footer>
      </div>
    </section>
  </main>
</Layout>

<script is:inline>
  document.querySelectorAll("[data-contact='email']").forEach((link) => {
    link.addEventListener("click", () => {
      window.posthog?.capture("product_support_contacted", {
        product: document.title,
      });
    });
  });
</script>
