---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import FullSign from "../components/FullSign.astro";
import Annotate from "../components/Annotate.astro";
import IframeDialog from "../components/IframeDialog.astro";
import EmailLink from "../components/EmailLink.astro";
import { siteLinks, heroStats, projects, hostname } from "../data/portfolio";
import {
  buildPersonSchema,
  buildProfilePageSchema,
  buildWebsiteSchema,
  siteConfig,
} from "../lib/seo";
import wavingHand from "../assets/emojis/waving-hand.webp";
import merlin from "../assets/emojis/merlin.webp";
import avatar from "../assets/icons/icon.png";

// Homepage uses the ProfilePage + Person + WebSite trio — Google's
// recommended combo for personal sites, which drives the Knowledge Panel
// and gives AI assistants a clear "this is a person" entity to cite.
const jsonLd = [
  buildProfilePageSchema(Astro.site),
  buildPersonSchema(Astro.site),
  buildWebsiteSchema(Astro.site),
];
---

<Layout
  title={siteConfig.name}
  description={siteConfig.description}
  jsonLd={jsonLd}
>
  <main class="isolate">
    <section class="section-shell">
      <div class="section-inner grid gap-16">
        <div class="grid gap-12">
          <div class="grid gap-4">
            <div class="grid gap-6">
              <p class="text-muted-foreground text-sm">
                {siteConfig.location.city}, {siteConfig.location.country}.
                Product engineer.
              </p>
              <h1
                class="max-w-[22ch] text-4xl leading-[1.25] font-semibold tracking-tight text-balance select-none md:text-6xl md:leading-[1.2]"
              >
                <span class="text-muted-foreground">Hi,</span>
                <Image
                  src={wavingHand}
                  alt="Waving hand"
                  width="96"
                  height="96"
                  quality={60}
                  class="inline-block size-[0.85em] translate-y-[-0.05em] align-middle"
                />
                <span class="text-muted-foreground">I'm</span>
                <Image
                  src={avatar}
                  alt="Milind"
                  width="64"
                  height="64"
                  quality={70}
                  class="ring-border/70 inline-block size-[0.9em] translate-y-[-0.05em] rounded-full object-cover align-middle ring-1 dark:ring-white/10"
                />
                <span class="text-foreground">Milind.</span>
                <span class="text-muted-foreground">I'm a</span>
                <span class="text-foreground">Product Engineer</span>
                <span class="text-muted-foreground">at</span>
                <Image
                  src={merlin}
                  alt="Merlin AI"
                  width="128"
                  height="128"
                  class="ring-border/70 inline-block size-[0.85em] translate-y-[-0.05em] cursor-pointer rounded-[0.2em] object-cover align-middle ring-1 transition-transform duration-300 ease-out hover:-rotate-[15deg] dark:ring-white/10"
                />
                <span class="text-foreground">Merlin AI.</span>
              </h1>
              <p
                class="text-muted-foreground max-w-[52ch] text-base text-pretty md:text-lg"
              >
                Working across the browser agent extension and Merlin's chat
                interface, where ambient AI meets everyday workflows.
              </p>
              <p
                class="text-muted-foreground max-w-[52ch] text-base text-pretty md:text-lg"
              >
                Always happy to talk shop with people building thoughtful
                products.
              </p>
              <EmailLink
                class="mt-2"
                emailClass="text-2xl sm:text-3xl md:text-4xl"
              />
            </div>
          </div>

          <div class="grid gap-3">
            <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
              <IframeDialog
                id="book"
                label="Book 15 minutes"
                title="Book 15 minutes"
                src="https://cal.com/milind/15min"
                triggerClass="font-medium"
              />
              <IframeDialog
                id="resume"
                label={siteLinks.resume.label}
                title="Milind's Resume"
                src={siteLinks.resume.pdf}
              />
              <a href="/blog">Read the blog</a>
            </div>
          </div>

          <div class="grid gap-2">
            <p class="text-muted-foreground text-sm">
              Working with teams abroad
            </p>
            <p class="text-muted-foreground max-w-[56ch] text-sm text-pretty">
              Based in {siteConfig.location.timezoneLabel}. I keep a 3–4 hour
              overlap with US mornings and most of the European workday, and I'm
              open to remote roles, B2B contractor, or EOR arrangements. Fluent
              in English.
            </p>
          </div>

          <div class="grid gap-10">
            <div class="flex items-baseline justify-between gap-4">
              <p class="text-muted-foreground text-sm">Selected work</p>
            </div>

            <ul role="list" class="divide-border/40 grid divide-y">
              {
                projects.map((project, index) => (
                  <li class="py-8 first:pt-0 last:pb-0">
                    <a
                      href={project.href}
                      target="_blank"
                      rel="noreferrer"
                      class="group grid gap-2 no-underline"
                      data-project-name={project.name}
                      data-project-href={project.href}
                    >
                      <h2 class="text-foreground text-xl font-medium tracking-tight sm:text-2xl">
                        {project.name}
                      </h2>
                      <p class="text-muted-foreground max-w-[56ch] text-sm text-pretty sm:text-base">
                        {project.description}
                      </p>
                      <span class="text-muted-foreground group-hover:text-foreground mt-1 inline-flex items-center gap-1 font-mono text-xs transition-colors">
                        {hostname(project.href)}
                        <Icon name="ri:arrow-right-up-line" class="size-3.5" />
                      </span>
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="md:divide-border/40 md:grid md:grid-cols-3 md:divide-x">
            {
              heroStats.map((stat, index) => (
                <div
                  class:list={[
                    "grid gap-1 py-6 md:py-0",
                    index === 0
                      ? "md:pr-6"
                      : index === heroStats.length - 1
                        ? "md:pl-6"
                        : "md:px-6",
                  ]}
                >
                  <p class="text-4xl font-semibold tracking-tight tabular-nums">
                    {stat.value}
                  </p>
                  <p class="text-muted-foreground text-sm text-pretty">
                    {stat.label}
                  </p>
                </div>
              ))
            }
          </div>
        </div>

        <div class="grid gap-4">
          <div class="grid gap-8">
            <div class="grid gap-4">
              <p class="text-muted-foreground text-sm">Where I'm headed</p>
              <h2
                class="max-w-[24ch] font-serif text-3xl font-normal tracking-tight text-balance italic md:text-4xl"
              >
                Toward design engineering, where <Annotate type="underline"
                  >craft and code</Annotate
                > meet at the surface.
              </h2>
              <p
                class="text-muted-foreground max-w-[56ch] text-base text-pretty"
              >
                I started as a product engineer who kept caring too much about
                how things looked and moved. Now I'm making that the focus. I
                build agentic flows, design systems, and interaction-heavy
                surfaces, and I'm sharpening my design intuition through close
                study of the people and work I admire, with AI accelerating how
                fast I can ship polished work.
              </p>
              <FullSign class="h-12 w-auto sm:h-14" />
            </div>

            <div class="grid gap-4 text-sm">
              <p class="text-muted-foreground">Quick navigation</p>
              <div class="flex flex-wrap gap-x-6 gap-y-2" id="quick-nav">
                <a href="/work" class="font-medium" data-nav-label="work"
                  >View my work experience</a
                >
                <a href="/talks" data-nav-label="talks">See my talks</a>
                <a href="/blog" data-nav-label="blog">Read my blog</a>
                <a href="/contact" data-nav-label="contact">Get in touch</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script is:inline>
  document.querySelectorAll("[data-project-name]").forEach((link) => {
    link.addEventListener("click", () => {
      window.posthog?.capture("project_clicked", {
        project_name: link.dataset.projectName,
        project_href: link.dataset.projectHref,
      });
    });
  });

  document.querySelectorAll("#quick-nav [data-nav-label]").forEach((link) => {
    link.addEventListener("click", () => {
      window.posthog?.capture("quick_nav_link_clicked", {
        destination: link.dataset.navLabel,
      });
    });
  });
</script>
