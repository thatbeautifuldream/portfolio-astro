---
import Layout from "../layouts/Layout.astro";
import Annotate from "../components/Annotate.astro";
import { roles } from "../data/portfolio";
import { absoluteUrl, buildPersonRef, siteConfig } from "../lib/seo";

const pageUrl = absoluteUrl("/work", Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `Work Experience · ${siteConfig.name}`,
  description:
    "Work across startup environments. Different products and teams, but a consistent pull toward the surfaces people touch and the craft behind them.",
  url: pageUrl,
  author: buildPersonRef(Astro.site),
  hasPart: roles.map((role) => ({
    "@type": "OrganizationRole",
    roleName: role.role,
    worksFor: { "@type": "Organization", name: role.company },
  })),
};
---

<Layout
  title="Work"
  description="Work across startup environments. Different products and teams, but a consistent pull toward the surfaces people touch and the craft behind them."
  jsonLd={jsonLd}
>
  <main class="isolate">
    <section class="section-shell">
      <div class="section-inner grid gap-12">
        <div class="grid gap-4">
          <p class="text-muted-foreground text-sm">Selected work</p>
          <h1
            class="max-w-[28ch] font-serif text-3xl font-normal tracking-tight text-balance italic md:text-5xl"
          >
            Product and AI work across startup environments.
          </h1>
          <p
            class="text-muted-foreground max-w-[56ch] text-base text-pretty md:text-lg"
          >
            Different products and teams, but a consistent pull toward the
            <Annotate type="underline">surfaces people touch</Annotate> and the craft
            behind them. I'm still sharpening that instinct, and honestly, that's
            what keeps the work alive for me.
          </p>
        </div>

        <div class="grid gap-4">
          <h2
            class="max-w-[24ch] text-2xl font-semibold tracking-tight md:text-3xl"
          >
            How I approach product work
          </h2>
          <p class="text-muted-foreground max-w-[56ch] text-base text-pretty">
            I care most about the surfaces people actually touch. Good product
            engineering means understanding not just the code, but how users
            move through a system and where their mental models break down.
          </p>
        </div>

        <div class="grid">
          {
            roles.map((role) => (
              <article class="border-border/60 grid gap-4 border-t py-10 first:border-t-0 first:pt-0">
                <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6">
                  <div class="grid gap-1">
                    <h2 class="text-xl font-semibold tracking-tight">
                      {role.company}
                    </h2>
                    <p class="text-muted-foreground text-base">{role.role}</p>
                  </div>
                  <p class="text-muted-foreground shrink-0 text-base sm:text-right sm:text-sm">
                    {role.period} · {role.location}
                  </p>
                </div>
                <p class="text-muted-foreground max-w-[60ch] text-base text-pretty">
                  {role.summary}
                </p>
                <ul role="list" class="grid max-w-[68ch] gap-2.5">
                  {role.highlights.map((highlight) => (
                    <li class="text-muted-foreground before:text-muted-foreground/40 relative pl-5 text-base text-pretty before:absolute before:left-0 before:content-['•']">
                      {highlight}
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
