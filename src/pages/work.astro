---
import Layout from "../layouts/Layout.astro";
import Annotate from "../components/Annotate.astro";
import { roles } from "../data/portfolio";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Work Experience — Milind Kumar Mishra",
  description:
    "Work across startup environments. Different products and teams, but a consistent pull toward the surfaces people touch and the craft behind them.",
  url: "https://milindmishra.com/work",
  author: {
    "@type": "Person",
    name: "Milind Kumar Mishra",
    url: "https://milindmishra.com",
  },
  hasPart: roles.map((role) => ({
    "@type": "OrganizationRole",
    roleName: role.role,
    worksFor: { "@type": "Organization", name: role.company },
  })),
};
---

<Layout
  title="Work"
  description="Work across startup environments. Different products and teams, but a consistent pull toward the surfaces people touch and the craft behind them."
  jsonLd={jsonLd}
>
  <main class="isolate">
    <section class="section-shell">
      <div class="section-inner grid gap-12">
        <div class="animate-fade-up grid gap-4" style="--stagger: 1">
          <p class="text-sm text-muted-foreground">Selected work</p>
          <h1
            class="max-w-[28ch] font-serif text-3xl font-normal italic tracking-tight text-balance md:text-5xl"
          >
            Product and AI work across startup environments.
          </h1>
          <p class="max-w-[56ch] text-base text-pretty text-muted-foreground md:text-lg">
            Different products and teams, but a consistent pull toward the
            <Annotate type="underline">surfaces people touch</Annotate> and the craft
            behind them. I'm still sharpening that instinct, and honestly, that's
            what keeps the work alive for me.
          </p>
        </div>

        <div class="animate-fade-up grid gap-4" style="--stagger: 2">
          <h2 class="max-w-[24ch] text-2xl font-semibold tracking-tight md:text-3xl">
            How I approach product work
          </h2>
          <p class="max-w-[56ch] text-base text-pretty text-muted-foreground">
            I care most about the surfaces people actually touch. Good product
            engineering means understanding not just the code, but how users
            move through a system and where their mental models break down.
          </p>
        </div>

        <div class="grid gap-12">
          {
            roles.map((role, index) => (
              <article
                class="animate-fade-up grid gap-4"
                style={`--stagger: ${3 + index}`}
              >
                <div class="grid gap-2">
                  <h2 class="text-2xl font-semibold tracking-tight">
                    {role.company}
                  </h2>
                  <p class="text-sm text-muted-foreground">
                    {role.role} · {role.period} · {role.location}
                  </p>
                </div>
                <p class="max-w-[56ch] text-base text-pretty text-muted-foreground">
                  {role.summary}
                </p>
                <ul role="list" class="grid max-w-[56ch] gap-3">
                  {role.highlights.map((highlight) => (
                    <li class="text-base text-pretty text-muted-foreground before:mr-2 before:text-muted-foreground/50 before:content-['–']">
                      {highlight}
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
