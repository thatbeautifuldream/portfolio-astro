---
import "../styles/global.css";
import { Font } from "astro:assets";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import GlobalIframeDialog from "../components/GlobalIframeDialog.astro";
import Analytics from "../components/Analytics.astro";
import PostHog from "../components/posthog.astro";
import {
  absoluteUrl,
  buildPersonSchema,
  buildWebsiteSchema,
  defaultKeywords,
  siteConfig,
} from "../lib/seo";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  keywords?: string[];
  image?: string;
  jsonLd?: unknown;
}

const {
  title = siteConfig.name,
  description = siteConfig.description,
  canonical,
  keywords,
  image = siteConfig.defaultImage,
  jsonLd,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
// Name-first so the installed PWA window doesn't repeat it: Chrome prefixes
// the manifest app name unless the title already starts with it.
const fullTitle =
  title === siteConfig.name
    ? `${siteConfig.shortName} · ${siteConfig.tagline}`
    : `${siteConfig.shortName} · ${title}`;
const ogImage = absoluteUrl(image, Astro.site);
const ogLogo = absoluteUrl("/icons/Icon-192.png", Astro.site);
const metaKeywords = keywords ?? defaultKeywords;
const robots =
  "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1";
const structuredData = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [buildPersonSchema(Astro.site), buildWebsiteSchema(Astro.site)];
---

<!doctype html>
<html lang="en" class="antialiased">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      // Apply the theme before paint; re-apply when the OS scheme changes
      // while no explicit preference is stored.
      (() => {
        const scheme = matchMedia("(prefers-color-scheme: dark)");
        const apply = () => {
          const stored = localStorage.getItem("theme");
          const dark =
            stored === "dark" || (stored !== "light" && scheme.matches);
          document.documentElement.classList.toggle("dark", dark);
        };
        apply();
        scheme.addEventListener("change", apply);
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="48x48 32x32 16x16" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <Font cssVariable="--font-inter" />
    <Font cssVariable="--font-google-sans-code" />
    <Font cssVariable="--font-libre-baskerville" />
    <script
      type="speculationrules"
      is:inline
      set:html={JSON.stringify({
        prerender: [
          {
            source: "document",
            where: {
              and: [
                { href_matches: "/*" },
                { not: { href_matches: "/*\\?*" } },
                { not: { selector_matches: '[rel~="nofollow"]' } },
                { not: { selector_matches: "[data-astro-reload]" } },
              ],
            },
            eagerness: "moderate",
          },
        ],
      })}
    />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={metaKeywords.join(", ")} />
    <meta name="theme-color" content={siteConfig.themeColor} />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    <meta name="application-name" content={siteConfig.name} />
    <meta name="format-detection" content="telephone=no" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${siteConfig.shortName} · Blog`}
      href={new URL("rss.xml", Astro.site)}
    />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:locale" content={siteConfig.locale} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta
      property="og:image:alt"
      content={`${siteConfig.name}: ${siteConfig.tagline}`}
    />
    <meta property="og:logo" content={ogLogo} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:creator" content={siteConfig.twitter} />

    {
      structuredData.map((schema) => (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(schema)}
        />
      ))
    }

    <Analytics />
    <PostHog />
  </head>
  <body class="bg-background text-foreground min-h-svh font-sans">
    <div
      class="mx-auto flex w-full max-w-[68rem] justify-center px-3 sm:px-4 xl:gap-6"
    >
      <Navigation />
      <div class="flex min-h-svh max-w-3xl min-w-0 flex-1 flex-col">
        <div class="grow">
          <slot />
        </div>
        <Footer />
      </div>
    </div>
    <GlobalIframeDialog />
    <script is:inline>
      document.addEventListener("keydown", (e) => {
        if (
          (e.metaKey || e.ctrlKey) &&
          !e.altKey &&
          !e.shiftKey &&
          e.key.toLowerCase() === "d"
        ) {
          e.preventDefault();
          document.getElementById("theme-toggle")?.click();
        }
      });
    </script>
  </body>
</html>
