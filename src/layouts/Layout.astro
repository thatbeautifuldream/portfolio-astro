---
import "../styles/global.css";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  jsonLd?: unknown;
}

const {
  title = "Milind Kumar Mishra",
  description = "Product engineer building AI-native interfaces, product systems, and tools people return to.",
  canonical,
  jsonLd,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const fullTitle =
  title === "Milind Kumar Mishra" ? title : `${title} · Milind Kumar Mishra`;
const ogImage = new URL("/icons/Icon-512.png", Astro.site).href;
---

<!doctype html>
<html lang="en" class="dark scheme-only-dark antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/icons/icon.png" />
    <meta name="generator" content={Astro.generator} />
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-google-sans-code" preload />
    <Font cssVariable="--font-libre-baskerville" />
    <ClientRouter />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Milind Kumar Mishra" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@milindmishra_" />

    {
      jsonLd && (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(jsonLd)}
        />
      )
    }
  </head>
  <body class="min-h-svh bg-background font-sans text-foreground">
    <Navigation />
    <slot />
    <Footer />
  </body>
</html>
