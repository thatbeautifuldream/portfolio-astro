---
import Sign from "./Sign.astro";
import { navItems } from "../data/portfolio";

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header class="fixed inset-x-0 top-0 z-50">
  <nav
    class="mx-auto flex max-w-3xl items-center justify-between gap-4 bg-background/80 px-4 py-3 backdrop-blur-lg sm:px-6"
  >
    <a href="/" aria-label="Homepage" class="no-underline hover:text-foreground">
      <Sign class="h-5 w-auto transition-transform duration-300 hover:scale-105" />
    </a>
    <ul
      role="list"
      class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm sm:gap-x-5"
    >
      {
        navItems
          .filter((item) => item.href !== "/")
          .map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "no-underline transition-colors hover:text-foreground",
                  isActive(item.href)
                    ? "text-foreground"
                    : "text-muted-foreground",
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
      }
    </ul>
  </nav>
</header>
