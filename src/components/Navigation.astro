---
import { Icon } from "astro-icon/components";
import Sign from "./Sign.astro";
import { navItems, siteLinks } from "../data/portfolio";

const links = navItems;
const cta = siteLinks.primaryCta;

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/"
    ? pathname === "/"
    : pathname === href || pathname.startsWith(href + "/");

const icons: Record<string, { line: string; fill: string }> = {
  "/": { line: "ri:home-5-line", fill: "ri:home-5-fill" },
  "/work": { line: "ri:briefcase-line", fill: "ri:briefcase-fill" },
  "/talks": { line: "ri:mic-line", fill: "ri:mic-fill" },
  "/blog": { line: "ri:article-line", fill: "ri:article-fill" },
  "/gist": { line: "ri:code-box-line", fill: "ri:code-box-fill" },
  "/contact": { line: "ri:mail-line", fill: "ri:mail-fill" },
};
---

<aside
  style="view-transition-name: nav"
  class="sticky top-0 flex h-dvh w-[60px] shrink-0 flex-col items-center gap-0.5 py-4 xl:w-60 xl:items-stretch xl:px-2"
>
  <a
    href="/"
    aria-label="Homepage"
    class="hover:text-foreground hover:bg-foreground/5 squircle mb-1 inline-flex size-11 items-center justify-center rounded-2xl no-underline transition-colors xl:ml-1"
  >
    <Sign class="h-6 w-auto" />
  </a>

  <nav class="flex w-full flex-col items-center gap-0.5 xl:items-start">
    {
      links.map((item) => (
        <a
          href={item.href}
          aria-label={item.label}
          aria-current={isActive(item.href) ? "page" : undefined}
          class="text-foreground hover:bg-foreground/5 aria-[current=page]:bg-foreground/10 group/rail squircle inline-flex items-center gap-5 rounded-2xl p-2.5 text-xl no-underline transition-colors aria-[current=page]:font-semibold xl:py-2.5 xl:pr-6 xl:pl-3"
        >
          <Icon
            name={icons[item.href]?.line ?? "ri:circle-line"}
            class="size-6 shrink-0 group-aria-[current=page]/rail:hidden"
          />
          <Icon
            name={icons[item.href]?.fill ?? "ri:circle-fill"}
            class="hidden size-6 shrink-0 group-aria-[current=page]/rail:block"
          />
          <span class="hidden xl:inline">{item.label}</span>
        </a>
      ))
    }
  </nav>

  <a
    href={cta.href}
    aria-label={cta.label}
    class="bg-foreground text-background squircle mt-3 inline-flex size-11 items-center justify-center rounded-2xl font-semibold no-underline transition-opacity hover:opacity-90 xl:mt-6 xl:h-12 xl:w-full xl:rounded-full xl:px-8"
  >
    <span class="hidden xl:inline">{cta.label}</span>
    <Icon name="ri:add-line" class="size-6 xl:hidden" />
  </a>
</aside>
