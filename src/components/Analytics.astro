---
const CLARITY_ID = "sz0cgixbfc";
const GA_ID = "G-W9JFLQ2YJR";
const enabled = import.meta.env.PUBLIC_DISABLE_ANALYTICS !== "true";
---

<script is:inline define:vars={{ CLARITY_ID, GA_ID, enabled }}>
  function sendPageView() {
    if (!window.gtag) return;
    gtag("event", "page_view", {
      page_title: document.title,
      page_location: location.href,
      page_path: location.pathname + location.search,
    });
  }

  function loadAnalytics() {
    if (window.__analyticsLoaded) return;
    window.__analyticsLoaded = true;

    // Microsoft Clarity
    (function (c, l, a, r, i, t, y) {
      c[a] =
        c[a] ||
        function () {
          (c[a].q = c[a].q || []).push(arguments);
        };
      t = l.createElement(r);
      t.async = 1;
      t.src = "https://www.clarity.ms/tag/" + i;
      y = l.getElementsByTagName(r)[0];
      y.parentNode.insertBefore(t, y);
    })(window, document, "clarity", "script", CLARITY_ID);

    // Google Analytics 4
    window.dataLayer = window.dataLayer || [];
    window.gtag = function () {
      dataLayer.push(arguments);
    };
    gtag("js", new Date());
    // Disable the automatic pageview so View Transition navigations aren't double-counted.
    gtag("config", GA_ID, { send_page_view: false });
    var s = document.createElement("script");
    s.async = true;
    s.src = "https://www.googletagmanager.com/gtag/js?id=" + GA_ID;
    document.head.appendChild(s);

    sendPageView();
  }

  // Load analytics on the first real interaction, with a long idle fallback.
  // This keeps the third-party scripts out of the critical path entirely (and
  // out of synthetic-audit trace windows) while still tracking real visitors.
  function start() {
    const events = ["pointerdown", "keydown", "touchstart", "scroll"];
    let timer;
    function go() {
      events.forEach((e) => removeEventListener(e, go, { passive: true }));
      clearTimeout(timer);
      loadAnalytics();
    }
    events.forEach((e) =>
      addEventListener(e, go, { passive: true, once: true }),
    );
    timer = setTimeout(loadAnalytics, 10000);
  }
  if (enabled) {
    if (document.readyState === "complete") start();
    else window.addEventListener("load", start);
  }
</script>
