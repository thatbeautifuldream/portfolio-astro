---
import { Icon } from "astro-icon/components";

interface Props {
  id: string;
  label: string;
  title: string;
  src: string;
  externalHref?: string;
  triggerClass?: string;
  bare?: boolean;
  class?: string;
}

const {
  id,
  label,
  title,
  src,
  externalHref,
  triggerClass,
  bare = false,
  class: className,
} = Astro.props;

const openHref = externalHref ?? src;
---

<button
  type="button"
  data-iframe-open={id}
  aria-label={label}
  class:list={[
    "cursor-pointer",
    !bare &&
      "text-foreground hover:text-muted-foreground underline decoration-1 underline-offset-4",
    triggerClass,
    className,
  ]}
>
  <slot>{label}</slot>
</button>

<dialog
  data-iframe-dialog={id}
  class="@container m-0 h-dvh max-h-none w-screen max-w-none bg-transparent p-0 backdrop:bg-black/50 backdrop:backdrop-blur-sm"
>
  <div
    class="bg-background text-foreground mx-auto flex h-full w-full flex-col @md:my-[2.5dvh] @md:h-[95dvh] @md:w-[min(90vw,900px)] @md:rounded-2xl"
  >
    <div
      class="border-border/60 flex items-center justify-between border-b px-3 py-1.5"
    >
      <p class="text-xs font-medium">{title}</p>
      <div class="flex items-center gap-0.5">
        <a
          href={openHref}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Open in new tab"
          class="text-muted-foreground hover:text-foreground hover:bg-foreground/5 inline-flex size-7 items-center justify-center rounded-lg no-underline"
        >
          <Icon name="ri:external-link-line" class="size-4" />
        </a>
        <button
          type="button"
          data-iframe-close
          aria-label="Close"
          class="text-muted-foreground hover:text-foreground hover:bg-foreground/5 inline-flex size-7 cursor-pointer items-center justify-center rounded-lg"
        >
          <Icon name="ri:close-line" class="size-4" />
        </button>
      </div>
    </div>
    <iframe
      data-iframe-frame
      title={title}
      class="h-full w-full flex-1 border-0"
      loading="lazy"></iframe>
  </div>
</dialog>

<script is:inline define:vars={{ id, src }}>
  const dialog = document.querySelector(`[data-iframe-dialog="${id}"]`);
  const frame = dialog?.querySelector("[data-iframe-frame]");

  document
    .querySelector(`[data-iframe-open="${id}"]`)
    ?.addEventListener("click", () => {
      if (frame && !frame.src) frame.src = src;
      dialog?.showModal();
      window.posthog?.capture("dialog_opened", {
        dialog_id: id,
        dialog_src: src,
      });
    });

  dialog
    ?.querySelector("[data-iframe-close]")
    ?.addEventListener("click", () => dialog.close());

  dialog?.addEventListener("click", (event) => {
    if (event.target === dialog) dialog.close();
  });
</script>
